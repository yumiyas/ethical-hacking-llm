
**.env.example:**
```env
# Server Configuration
HOST=0.0.0.0
PORT=3000
RUST_LOG=info
WORKERS=4

# Model Configuration
MODEL_PATH=./models/phi-2-q4/phi-2-q4.gguf
TOKENIZER_PATH=./models/phi-2-q4/tokenizer.json
MODEL_TYPE=quantized
MAX_TOKENS=512
TEMPERATURE=0.7
TOP_P=0.9

# Cache Configuration
REDIS_URL=redis://localhost:6379
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_MAX_SIZE=10000

# Security Configuration
RATE_LIMIT=100
JWT_SECRET=your-256-bit-secret-key-change-in-production
MAX_QUERY_LENGTH=1000

# API Keys (Optional)
HUGGINGFACE_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# Database
DATABASE_URL=sqlite:./data/cache/responses.db

# Monitoring
METRICS_ENABLED=true
OTLP_ENDPOINT=http://localhost:4317
