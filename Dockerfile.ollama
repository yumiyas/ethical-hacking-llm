FROM ollama/ollama:latest

# Install additional tools
RUN apt-get update && apt-get install -y \
    curl \
    jq \
    && rm -rf /var/lib/apt/lists/*

# Create directories
RUN mkdir -p /root/{models,ollama,scripts}

# Copy Modelfile and scripts
COPY ollama/Modelfile /root/ollama/Modelfile
COPY ollama/ollama_push.sh /root/scripts/
COPY scripts/deploy_ollama.sh /root/scripts/

# Copy knowledge base
COPY data/knowledge_base/ /root/knowledge_base/

# Make scripts executable
RUN chmod +x /root/scripts/*.sh

# Copy entrypoint
COPY ollama-entrypoint.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/ollama-entrypoint.sh

# Create volume for models
VOLUME ["/root/.ollama"]

# Expose ports
EXPOSE 11434

# Set entrypoint
ENTRYPOINT ["/usr/local/bin/ollama-entrypoint.sh"]

# Default command
CMD ["ollama", "serve"]
