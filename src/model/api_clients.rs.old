use anyhow::Result;
use async_trait::async_trait;
use serde::{Deserialize, Serialize};
use std::collections::HashMap;

#[async_trait]
pub trait AIClient: Send + Sync {
    async fn generate(&self, prompt: &str, max_tokens: usize) -> Result<String>;
    fn name(&self) -> &'static str;
}

// 1. Ollama API (Local, Unlimited)
pub struct OllamaClient {
    endpoint: String,
    model: String,
    client: reqwest::Client,
}

impl OllamaClient {
    pub fn new(endpoint: &str, model: &str) -> Self {
        Self {
            endpoint: endpoint.to_string(),
            model: model.to_string(),
            client: reqwest::Client::new(),
        }
    }
}

#[async_trait]
impl AIClient for OllamaClient {
    async fn generate(&self, prompt: &str, max_tokens: usize) -> Result<String> {
        let response = self.client
            .post(&format!("{}/api/generate", self.endpoint))
            .json(&serde_json::json!({
                "model": self.model,
                "prompt": prompt,
                "stream": false,
                "options": {
                    "num_predict": max_tokens,
                    "temperature": 0.7
                }
            }))
            .send()
            .await?;
        
        let data: serde_json::Value = response.json().await?;
        Ok(data["response"].as_str().unwrap_or("").to_string())
    }
    
    fn name(&self) -> &'static str {
        "Ollama"
    }
}

// 2. LocalAI (Self-hosted, Unlimited)
pub struct LocalAIClient {
    endpoint: String,
    model: String,
    client: reqwest::Client,
}

#[async_trait]
impl AIClient for LocalAIClient {
    async fn generate(&self, prompt: &str, max_tokens: usize) -> Result<String> {
        let response = self.client
            .post(&format!("{}/v1/completions", self.endpoint))
            .json(&serde_json::json!({
                "model": self.model,
                "prompt": prompt,
                "max_tokens": max_tokens,
                "temperature": 0.7
            }))
            .send()
            .await?;
        
        let data: serde_json::Value = response.json().await?;
        Ok(data["choices"][0]["text"].as_str().unwrap_or("").to_string())
    }
    
    fn name(&self) -> &'static str {
        "LocalAI"
    }
}

